# =============================================
# SEC 13F Chat - Snowflake Configuration
# =============================================
# Copy this file to secrets.toml and configure with YOUR credentials
# DO NOT commit secrets.toml to git!

# Snowflake Connection
SNOWFLAKE_USER = "your_snowflake_username"
SNOWFLAKE_ACCOUNT = "your_account.your_region"
SNOWFLAKE_WAREHOUSE = "your_warehouse"
SNOWFLAKE_DATABASE = "SEC_13F_ANALYTICS"
SNOWFLAKE_SCHEMA = "SEMANTIC_LAYER"

# =============================================
# Key Pair Authentication (REQUIRED)
# =============================================
# Generate keys with:
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out rsa_key.p8 -nocrypt
#   openssl rsa -in rsa_key.p8 -pubout -out rsa_key.pub
#
# Then assign public key in Snowflake:
#   ALTER USER your_username SET RSA_PUBLIC_KEY='...';

SNOWFLAKE_PRIVATE_KEY = """-----BEGIN PRIVATE KEY-----
PASTE_YOUR_PRIVATE_KEY_HERE
-----END PRIVATE KEY-----"""

# =============================================
# Cortex & View Settings
# =============================================
SEMANTIC_VIEW = "SEC_13F_HOLDINGS_ANALYTICS"
CORTEX_MODEL = "mistral-large"
